# Configuración del servidor
PORT=3000
PUBLIC_URL=http://localhost:3000
NODE_ENV=development

# MongoDB Atlas - Reemplazar con tus credenciales
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
DB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/bildyapp?retryWrites=true&w=majority

# JWT
JWT_SECRET=tu_secreto_jwt_aqui
JWT_EXPIRES_IN=7d

# Email (Nodemailer - Gmail / SendGrid / Mailtrap)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion
EMAIL_FROM=noreply@bildyapp.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Slack Incoming Webhook (para logging de errores 5XX)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
