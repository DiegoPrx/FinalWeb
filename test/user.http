### Variables
@baseUrl = http://localhost:3000/api
@token = TU_TOKEN_AQUI

### ==========================================
### USUARIOS
### ==========================================

### Registrar usuario
POST {{baseUrl}}/user/register
Content-Type: application/json

{
  "email": "diego@test.com",
  "password": "123456"
}

### Login
POST {{baseUrl}}/user/login
Content-Type: application/json

{
  "email": "diego@test.com",
  "password": "123456"
}

### Verificar email
PUT {{baseUrl}}/user/validation
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "code": "123456"
}

### Actualizar datos personales
PUT {{baseUrl}}/user/register
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Diego",
  "surnames": "Pérez Pastor",
  "nif": "12345678A",
  "phone": "600123456"
}

### Crear/actualizar compañía
PATCH {{baseUrl}}/user/company
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Mi Empresa S.L.",
  "cif": "B12345678",
  "street": "Calle Mayor",
  "number": "10",
  "postal": "28001",
  "city": "Madrid",
  "province": "Madrid"
}

### Subir logo (multipart)
PATCH {{baseUrl}}/user/logo
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="logo"; filename="logo.png"
Content-Type: image/png

< ./logo.png
--boundary--

### Obtener usuario autenticado
GET {{baseUrl}}/user
Authorization: Bearer {{token}}

### Eliminar usuario (soft delete)
DELETE {{baseUrl}}/user?soft=true
Authorization: Bearer {{token}}

### Eliminar usuario (hard delete)
DELETE {{baseUrl}}/user?soft=false
Authorization: Bearer {{token}}
